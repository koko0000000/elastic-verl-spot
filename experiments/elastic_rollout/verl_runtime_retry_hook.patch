+    async def kill_server_for_fault_injection(self, server_index: int = 0, no_restart: bool = True) -> dict:
+        """Kill one rollout server replica through the load balancer.
+
+        This is a test hook. Without higher-level retry/rebuild, the current
+        training step may fail after the injected rollout server death.
+        """
+
+        if not self.server_addresses:
+            return {"killed": False, "reason": "no_servers"}
+        if server_index < 0 or server_index >= len(self.server_addresses):
+            return {
+                "killed": False,
+                "reason": "server_index_out_of_range",
+                "server_index": server_index,
+                "num_servers": len(self.server_addresses),
+            }
+
+        server_id = self.server_addresses[server_index]
+        result = await self.global_load_balancer.kill_server.remote(server_id=server_id, no_restart=no_restart)
+        result["server_index"] = server_index
+        return result
+
+    @auto_await
+    async def configure_runtime_fault_injection(
+        self,
+        server_index: int = 0,
+        after_dispatches: int = 1,
+        delay_sec: float = 0.5,
+        no_restart: bool = True,
+    ) -> dict:
+        """Arm a delayed server kill that fires after real request dispatch starts."""
+
+        if not self.server_addresses:
+            return {"configured": False, "reason": "no_servers"}
+        if server_index < 0 or server_index >= len(self.server_addresses):
+            return {
+                "configured": False,
+                "reason": "server_index_out_of_range",
+                "server_index": server_index,
+                "num_servers": len(self.server_addresses),
+            }
+
+        server_id = self.server_addresses[server_index]
+        result = await self.global_load_balancer.configure_runtime_fault_injection.remote(
+            server_id=server_id,
+            after_dispatches=after_dispatches,
+            delay_sec=delay_sec,
+            no_restart=no_restart,
+        )
+        result["server_index"] = server_index
+        return result
+
+    @auto_await
+    async def get_runtime_fault_result(self) -> dict | None:
+        """Return the delayed server kill result if runtime injection has fired."""
+
+        result = await self.global_load_balancer.get_runtime_fault_result.remote()
+        if result is None:
+            return None
+        server_id = result.get("server_id")
